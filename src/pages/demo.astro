        { ts: '10:12 AM', msg: 'Ok thanks. Any idea how long?', type: 'in' },
        { ts: '10:12 AM', msg: 'Our vendor typically responds within 2–4 hours for priority issues. You\'ll get a text when they\'re on their way.', type: 'out' },
      ]
    },
    3: {
      type: 'PLUMBING · URGENT',
      title: '💧 Riverside Flats Unit 1A — Water through ceiling',
      meta: 'Priya Sharma · (252) 555-0198 · 3 hours ago',
      convo: [
        { ts: 'Today, 8:55 AM — Voicemail received', msg: '🎙️ "This is Priya in 1A, there\'s water coming through my ceiling in the bathroom, it\'s dripping pretty fast. I don\'t know what to do."', type: 'in' },
        { ts: '8:55 AM — Transcribed & triaged by Aitha PM', msg: null, type: 'system', label: 'Classified: VENDOR NEEDED · Urgent · Water intrusion' },
        { ts: '8:55 AM', msg: 'Hi Priya — we received your voicemail about water coming through your ceiling. This needs immediate attention. Our plumber has been notified. Please put a bucket or towels down if you can. Someone will be in touch very shortly.', type: 'out' },
        { ts: '8:57 AM — JBM Plumbing notified', msg: null, type: 'system', label: 'Vendor dispatched · Investigating unit above (2A)' },
      ]
    },
    4: {
      type: 'ELECTRICAL · SELF-FIX ATTEMPTED',
      title: '⚡ Maple Ridge Unit 7C — Power out in half the unit',
      meta: 'Diana Ross · (252) 555-0177 · 5 hours ago',
      convo: [
        { ts: 'Today, 6:45 AM — Voicemail received', msg: '🎙️ "Hi this is Diana in 7C, half the lights in my apartment went out this morning, like the bedroom and the bathroom work but the living room and kitchen don\'t."', type: 'in' },
        { ts: '6:45 AM — Transcribed & triaged by Aitha PM', msg: null, type: 'system', label: 'Classified: SELF-FIX CHECK · Possible tripped breaker' },
        { ts: '6:45 AM', msg: 'Hi Diana — this sounds like it could be a tripped circuit breaker, which you can reset yourself in about 2 minutes. Would you like to try that first?', type: 'out' },
        { ts: '6:48 AM', msg: 'Sure I can try that', type: 'in' },
        { ts: '6:48 AM', msg: 'Great! Here\'s how: 1) Find your breaker panel — usually a gray metal box in a closet or hallway. 2) Look for any switch that\'s in the middle position or flipped opposite to the others. 3) Push it firmly to OFF then back to ON. Let me know if that fixes it!', type: 'out' },
        { ts: '7:02 AM', msg: 'It didn\'t work, the switch looks fine', type: 'in' },
        { ts: '7:02 AM', msg: 'No problem at all — we\'ll get an electrician out to take a look. Management has been notified and will follow up shortly.', type: 'out' },
        { ts: '7:04 AM — Chandler Electric dispatched', msg: null, type: 'system', label: 'Vendor dispatched · Scheduled this afternoon' },
      ]
    },
    5: {
      type: 'PLUMBING · SELF-FIX IN PROGRESS',
      title: '🚿 Oak Commons Unit 2A — Kitchen sink draining slow',
      meta: 'Keisha Brown · (252) 555-0163 · 6 hours ago',
      convo: [
        { ts: 'Today, 6:10 AM — Voicemail received', msg: '🎙️ "Hey it\'s Keisha in 2A, my kitchen sink is draining really slow, like almost not at all. Just wanted to let someone know."', type: 'in' },
        { ts: '6:10 AM — Transcribed & triaged by Aitha PM', msg: null, type: 'system', label: 'Classified: SELF-FIX CHECK · Clogged drain' },
        { ts: '6:10 AM', msg: 'Hi Keisha — a slow drain is often something you can clear yourself quickly. Would you like me to walk you through it?', type: 'out' },
        { ts: '6:14 AM', msg: 'Yes please!', type: 'in' },
        { ts: '6:14 AM', msg: 'Here are the steps: 1) Remove any visible debris from the drain opening. 2) Pour a kettle of boiling water down the drain slowly. 3) Follow with a mix of 1/2 cup baking soda and 1/2 cup white vinegar. 4) Cover and wait 15 minutes. 5) Flush with hot water. Let me know how it goes!', type: 'out' },
        { ts: '6:14 AM — Awaiting tenant response', msg: null, type: 'system', label: 'Self-fix instructions sent · Standing by' },
      ]
    },
    6: {
      type: 'RENTAL INQUIRY',
      title: '🏠 Maple Ridge — Vacancy inquiry, 2BR unit',
      meta: 'Angela Reeves · (252) 555-0189 · Yesterday',
      convo: [
        { ts: 'Yesterday, 2:30 PM — Voicemail received', msg: '🎙️ "Hi I saw a sign on Maple Ridge Road about available units. I\'m looking for a 2 bedroom. Can someone give me more info or a number to call back?"', type: 'in' },
        { ts: '2:30 PM — Transcribed & triaged by Aitha PM', msg: null, type: 'system', label: 'Classified: RENTAL INQUIRY' },
        { ts: '2:30 PM', msg: 'Hi Angela — thanks for reaching out about Maple Ridge! We do have a 2BR unit available. Here\'s a link to current listings and floor plans: bridgepoint.com/rentals. Feel free to reply here with any questions or to schedule a showing.', type: 'out' },
        { ts: '2:45 PM — Manager notified', msg: null, type: 'system', label: 'Sarah Mitchell alerted · Listings link sent' },
        { ts: '3:12 PM', msg: 'Thank you! What\'s the rent and when is it available?', type: 'in' },
        { ts: '3:12 PM', msg: 'Our property manager Sarah will follow up with full details and availability within one business day. She can also schedule a showing at a time that works for you.', type: 'out' },
      ]
    },
    7: {
      type: 'LEASE INQUIRY · RESOLVED',
      title: '🔑 Riverside Flats Unit 5D — Lease renewal question',
      meta: 'Daniel Rivera · (252) 555-0155 · Yesterday',
      convo: [
        { ts: 'Yesterday, 10:15 AM — Voicemail received', msg: '🎙️ "Hey this is Daniel in 5D, my lease is up in August and I wanted to know what the process is for renewing and if the rent is going to change."', type: 'in' },
        { ts: '10:15 AM — Transcribed & triaged by Aitha PM', msg: null, type: 'system', label: 'Classified: QUESTION · Lease renewal' },
        { ts: '10:15 AM', msg: 'Hi Daniel — great to hear you\'re thinking about renewing! Our standard renewal process starts 90 days before your lease end date. Your property manager will reach out in May with renewal terms. If you\'d like to discuss early, reply here and we\'ll get Sarah in touch with you.', type: 'out' },
        { ts: '10:18 AM', msg: 'Perfect, that\'s all I needed. Thanks!', type: 'in' },
        { ts: '10:18 AM', msg: 'You\'re welcome Daniel — we\'re glad to have you at Riverside Flats. We\'ll be in touch in May!', type: 'out' },
        { ts: '10:18 AM — Resolved', msg: null, type: 'system', label: '✓ Resolved · No further action needed' },
      ]
    },
  };

  function switchView(view, el) {
    requestAnimationFrame(() => {
      document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
      el.classList.add('active');
      document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
      document.getElementById('view-' + view).classList.add('active');
      const titles = { incidents: 'Incidents', tenants: 'Tenants', properties: 'Properties', vendors: 'Vendors' };
      document.getElementById('view-title').textContent = titles[view];
      document.getElementById('incident-filters').style.display = view === 'incidents' ? 'flex' : 'none';
      closeDetail();
    });
  }

  function openDetail(id) {
    const d = incidents[id];
    if (!d) return;
    document.querySelectorAll('.incident-card').forEach(c => c.classList.remove('active'));
    const card = document.querySelector('[data-id="' + id + '"]');
    if (card) card.classList.add('active');
    document.getElementById('detail-panel').classList.add('open');
    requestAnimationFrame(() => {
      document.getElementById('d-type').textContent = d.type;
      document.getElementById('d-title').textContent = d.title;
      document.getElementById('d-meta').textContent = d.meta;
      let html = '<div class="convo-label">Conversation Thread</div>';
      d.convo.forEach(m => {
        if (m.type === 'system') {
          html += `<div class="msg"><div class="bubble system">${m.label}</div></div>`;
        } else if (m.type === 'out') {
          html += `<div class="msg out-wrap"><div class="msg-ts">${m.ts}</div><div class="bubble out">${m.msg}</div><div class="clearfix"></div></div>`;
        } else {
          html += `<div class="msg"><div class="msg-ts">${m.ts}</div><div class="bubble in">${m.msg}</div></div>`;
        }
      });
      document.getElementById('d-body').innerHTML = html;
      setTimeout(() => { const b = document.getElementById('d-body'); if (b) b.scrollTop = b.scrollHeight; }, 50);
    });
  }

  function closeDetail() {
    document.getElementById('detail-panel').classList.remove('open');
    document.querySelectorAll('.incident-card').forEach(c => c.classList.remove('active'));
  }

  function filterIncidents(status, btn) {
    requestAnimationFrame(() => {
      document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.incident-card').forEach(card => {
        card.style.display = (status === 'all' || card.dataset.status === status) ? 'flex' : 'none';
      });
    });
  }
</script>

</body>
</html>
