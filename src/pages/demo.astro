      convo: [
        { ts: 'Today, 9:44 AM — Voicemail received', msg: '🎙️ "Hey it\'s Marcus in 4B, my AC is blowing warm air and it\'s like 84 degrees in here. Can someone come look at it today?"', type: 'in' },
        { ts: '9:44 AM — Transcribed & triaged by Aitha PM', msg: null, type: 'system', label: 'Classified: VENDOR NEEDED · High priority HVAC' },
        { ts: '9:44 AM', msg: 'Hi Marcus — we received your voicemail. I\'ve logged this as a priority HVAC issue for Unit 4B. Our HVAC vendor has been notified and will contact you today to schedule. We\'ll keep you posted.', type: 'out' },
