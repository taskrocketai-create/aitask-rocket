---
import Layout from '../layouts/TaskRocketLayout.astro';
---
<Layout title="Free Workflow Review | TaskRocket" description="Request a TaskRocket workflow review.">
  <section class="section"><div class="container grid2"><div><div class="eyebrow">Free Workflow Review</div><h1>Show us where calls, messages, or admin work slow you down.</h1><p class="lead">TaskRocket will review your workflow and recommend practical automation options.</p><p class="small">SMS consent on this form is optional—you can submit this request without opting in to text messages.</p></div><form class="form-panel" method="post" action="https://formsubmit.co/info@taskrocket.org"><div class="form-grid"><input type="hidden" name="_subject" value="TaskRocket Workflow Review Request" /><input type="hidden" name="_captcha" value="false" /><input type="hidden" name="_template" value="table" /><div><label for="first">First name</label><input id="first" name="first" required /></div><div><label for="last">Last name</label><input id="last" name="last" required /></div><div><label for="business">Business name</label><input id="business" name="business" required /></div><div><label for="email">Email</label><input id="email" name="email" type="email" required /></div><div><label for="phone">Phone number</label><input id="phone" name="phone" type="tel" /></div><div><label for="type">Business type</label><select id="type" name="type"><option>Service business</option><option>Property management</option><option>Contractor</option><option>Local office</option><option>Other</option></select></div><div class="full"><label for="help">What do you want help automating?</label><textarea id="help" name="help"></textarea></div><div class="full"><label for="time">Best time to contact you</label><input id="time" name="time" /></div><div class="sms"><input id="sms" name="sms_consent" type="checkbox" /><p><label for="sms">By checking this box, I consent to receive text messages from TaskRocket related to my inquiry, workflow review, demo request, scheduling, service updates, and account communication. Message frequency varies. Message and data rates may apply. Reply STOP to unsubscribe or HELP for help. Consent is not a condition of purchase. View our <a href="/privacy-policy">Privacy Policy</a> and <a href="/sms-terms">SMS Terms & Conditions</a>.</label></p></div><p class="full small">We do not sell or share SMS consent with third parties for marketing purposes.</p><div class="full"><button class="btn orange" type="submit">Submit Workflow Review Request</button></div></div></form></div></section>
</Layout>
