---
import Layout from '../layouts/TaskRocketLayout.astro';
---
<Layout title="TaskRocket Services" description="Automation services for local businesses.">
  <section class="section"><div class="container"><div class="eyebrow">Services</div><h1>Automation built around the way your business actually works.</h1><p class="lead">TaskRocket reviews your workflow and builds practical automations around your team and tools.</p><div class="actions"><a class="btn orange" href="https://taskrocket.fillout.com/freebusinessreview" target="_blank" rel="noopener noreferrer">Get a Free Workflow Review</a><a class="btn light" href="/aitha">Meet Aitha</a></div></div></section>
  <section class="section"><div class="container grid"><div class="card"><h3>Missed Call Systems</h3><p>Recover calls your team cannot answer.</p></div><div class="card"><h3>Customer Intake</h3><p>Collect the information your staff needs.</p></div><div class="card"><h3>Escalation Rules</h3><p>Send urgent issues to the right person.</p></div><div class="card"><h3>Property Response</h3><p>Support tenant requests and vendor routing.</p></div><div class="card"><h3>Service Business Workflows</h3><p>Reduce manual admin time.</p></div><div class="card"><h3>Tool Connections</h3><p>Connect forms, calendars, CRMs, task boards, and email.</p></div></div></section>
</Layout>
