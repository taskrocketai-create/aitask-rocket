<script>
  function toggleFlow() {
    const content = document.getElementById('flow-content');
    const icon = document.getElementById('flow-icon');
    const btn = document.getElementById('flow-toggle');
    const isOpen = content.style.display !== 'none';
    content.style.display = isOpen ? 'none' : 'block';
    icon.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(45deg)';
    btn.querySelector('span:first-child').textContent = isOpen ? 'See the full after-hours call flow →' : 'Close the flow diagram';
  }
</script>

