---
import '../styles/global.css';
const { title = 'TaskRocket', description = 'Business automation for busy local businesses.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <header class="site-header">
      <div class="container nav">
        <a class="brand" href="/">Task<span>Rocket</span></a>
        <div class="nav-links">
          <a href="/services">Services</a>
          <a href="/aitha">Aitha</a>
          <a href="/contact">Free Workflow Review</a>
        </div>
      </div>
    </header>
    <main><slot /></main>
    <footer class="site-footer">
      <div class="container footer-grid">
        <div><h3>TaskRocket</h3><p>AI consulting and business automation for busy local businesses.</p></div>
        <div><h3>Company</h3><a href="/services">Services</a><a href="/aitha">Aitha</a><a href="/contact">Free Workflow Review</a></div>
       <div><h3>Legal</h3><a href="/privacy-policy">Privacy Policy</a><a href="/terms-of-service">Terms of Service</a><a href="/sms-terms">SMS Terms & Conditions</a><a href="/messaging-compliance">Messaging Compliance</a><a href="/sms-opt-in">SMS Opt-In</a></div>
      </div>
      <div class="container"><p class="disclosure">Messaging disclosure: By submitting a form and opting in to SMS, you agree to receive text messages from TaskRocket related to your inquiry, workflow review, demo request, scheduling, service updates, and account communication. Message frequency varies. Message and data rates may apply. Reply STOP to unsubscribe or HELP for help. Consent is not a condition of purchase.</p></div>
    </footer>
  </body>
</html>
